# REQUIRED
JWT_SECRET_KEY=<genera-un-secret-de-32-chars-aqui>
# REQUIRED
ADMIN_PASSWORD=<pon-una-password-segura>
# REQUIRED
INTERNAL_TOKEN=<token-interno-seguro>
# REQUIRED
DATABASE_URL=postgresql+asyncpg://app_user:change_me@db:5432/super_agent_platform
# REQUIRED
POSTGRES_USER=app_user
# REQUIRED
POSTGRES_PASSWORD=change_me
# REQUIRED
POSTGRES_DB=super_agent_platform
# REQUIRED
EVOLUTION_API_URL=https://evo.zapata.com
# REQUIRED
EVOLUTION_API_KEY=change-me
# REQUIRED
MONDAY_API_KEY=change-me
# REQUIRED
MONDAY_BOARD_ID=123456789
# REQUIRED
BRANCH_SHEET_URL=https://docs.google.com/spreadsheets/d/e/your-branches-sheet/pub?output=csv
# REQUIRED
INVENTORY_SHEET_URL=https://docs.google.com/spreadsheets/d/e/your-inventory-sheet/pub?output=csv
# OPTIONAL ALIAS (equivale a INVENTORY_SHEET_URL)
SHEET_CSV_URL=
# REQUIRED
DOMAIN=tudominio.com
# REQUIRED
ENVIRONMENT=production
# OPTIONAL
SENTRY_DSN=
# OPTIONAL
APP_VERSION=1.0.0

# OPTIONAL
ADMIN_USERNAME=admin
# OPTIONAL
LOG_LEVEL=INFO
# OPTIONAL
BRAND_PATH=brand
# OPTIONAL
CAMPAIGN_SCHEDULER_ENABLED=true
# OPTIONAL
CAMPAIGN_BATCH_SIZE=10
# OPTIONAL
CAMPAIGN_RATE_LIMIT_MS=300
# OPTIONAL
CAMPAIGN_SCHEDULER_INTERVAL_SECONDS=60
# OPTIONAL
ACCESS_TOKEN_EXPIRE_MINUTES=480
# OPTIONAL
APP_ENV=development
# OPTIONAL (recomendado false en produccion para evitar inventario estatico)
INVENTORY_FALLBACK_ENABLED=false
# OPTIONAL (debounce de mensajes entrantes para responder en bloque)
MESSAGE_ACCUMULATION_SECONDS=2
# OPTIONAL
OPENAI_API_KEY=
# OPTIONAL
OPENAI_MODEL_NAME=gpt-4o-mini
# OPTIONAL
VERTEX_MODEL_NAME=gemini-2.5-flash
# OPTIONAL
VERTEX_FALLBACK_MODEL_NAME=gemini-2.5-flash-lite
